{
  "Verbose": false,
  "Debug": false,
  "IgnoreDefaults": false,
  "SpacesAfterTabs": true,
  "NoColor": false,
  "Exclude": [
    "build/",
    "out/",
    "target/",
    "tmp/",
    "^LICENSE",
    "devcontainer-lock\\.json$",
    "\\.cdx\\.json$",
    "cobertura\\.xml",
    "lcov\\.info$",
    "\\.der$"
  ],
  "Disable": {
    "EndOfLine": false,
    "Indentation": false,
    "InsertFinalNewline": false,
    "TrimTrailingWhitespace": false,
    "IndentSize": false,
    "MaxLineLength": true
  }
}
